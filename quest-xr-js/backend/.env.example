# Copia este archivo a backend/.env y rellena los valores reales.
# backend/.env está en .gitignore — NUNCA lo commitees (contiene secretos).

# --- Servidor ---
PORT=8787

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_API_KEY_AUDIO=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_ENTERPRISE=
# Overrides opcionales de modelo (ver configs/gemini.config.js para defaults):
GEMINI_LIVE_MODEL=
GEMINI_VISION_MODEL=
GEMINI_PRO_MODEL=
GEMINI_ROUTER_MODEL=

# --- Pipeline de OBJETO (Sketchfab + Meshy) ---
SKETCHFAB_API_TOKEN=
MESHY_API_KEY=
MESHY_AI_MODEL=meshy-6
MESHY_ENABLE_PBR=true
# Dir local para modelos Sketchfab extraidos (default: backend/.models-cache)
OBJECT_MODEL_DIR=
# URL HTTPS de ngrok (mismo tunel que el WS). NO localhost/IP-LAN (WebXR = HTTPS).
MODEL_PUBLIC_BASE_URL=
SKETCHFAB_SEARCH_COUNT=24
MESHY_POLL_INTERVAL_MS=5000
MESHY_POLL_TIMEOUT_MS=300000
OBJECT_WAIT_PROGRESS_THROTTLE_MS=30000
